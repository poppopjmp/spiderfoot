        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "API CPU Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(process_cpu_seconds_total{job=\"spiderfoot-api\"}[5m])",
          "legendFormat": "CPU",
          "instant": true,
          "refId": "A"
        }
      ]
    },
