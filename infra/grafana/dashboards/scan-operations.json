{
  "uid": "sf-scans",
  "title": "SpiderFoot — Scan Operations",
  "description": "API process health, Celery worker pipeline, and scan-related logs. Scan metric panels will auto-populate once the SpiderFoot API exports sf_scans_* Prometheus metrics.",
  "tags": ["spiderfoot", "scans", "operations"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
