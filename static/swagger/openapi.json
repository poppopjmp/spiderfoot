{
  "openapi": "3.0.0",
  "info": {
    "title": "SpiderFoot API",
    "description": "API for SpiderFoot OSINT automation tool",
    "version": "3.5"
  },
  "servers": [
    {
      "url": "/api",
      "description": "SpiderFoot API Server"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "summary": "Test connectivity",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": ["SUCCESS", "3.5"]
                }
              }
            }
          }
        }
      }
    },
    "/scanlist": {
      "get": {
        "summary": "Get list of scans",
        "responses": {
          "200": {
            "description": "List of scans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/startscan": {
      "get": {
        "summary": "Start a new scan",
        "parameters": [
          {
            "name": "scanname",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scantarget",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modulelist",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typelist",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "usecase",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["all", "footprint", "investigate", "passive"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "scan_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}