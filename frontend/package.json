{
  "name": "spiderfoot-ui",
  "version": "6.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "description": "SpiderFoot Modern Web UI — React SPA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:api": "cd .. && python dump_openapi.py && cd frontend && npx openapi-ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.2",
    "lucide-react": "^0.577.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.14.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/client-axios": "^0.9.1",
    "@hey-api/openapi-ts": "^0.92.4",
    "@tailwindcss/forms": "^0.5.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.1"
  }
}
